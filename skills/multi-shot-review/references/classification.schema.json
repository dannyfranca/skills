{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "target", "changed_files", "areas", "native_eligibility", "contextual_risks", "user_directive_coverage", "slices", "coverage"],
  "properties": {
    "version": {"const": 1},
    "target": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["kind"], "properties": {"kind": {"const": "uncommitted"}}},
        {"type": "object", "additionalProperties": false, "required": ["kind", "value"], "properties": {"kind": {"const": "commit"}, "value": {"type": "string", "minLength": 1}}},
        {"type": "object", "additionalProperties": false, "required": ["kind", "value", "head"], "properties": {"kind": {"const": "base"}, "value": {"type": "string", "minLength": 1}, "head": {"type": "string", "minLength": 1}}}
      ]
    },
    "changed_files": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "areas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "files", "architecture_change", "database", "risk_flags"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"},
          "kind": {"enum": ["runtime", "executable", "docs", "metadata"]},
          "files": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "architecture_change": {"type": "boolean"},
          "database": {
            "type": "object",
            "additionalProperties": false,
            "required": ["changed", "multiple_behaviors", "transaction_complexity", "migration_or_backfill", "performance_sensitive"],
            "properties": {
              "changed": {"type": "boolean"},
              "multiple_behaviors": {"type": "boolean"},
              "transaction_complexity": {"type": "boolean"},
              "migration_or_backfill": {"type": "boolean"},
              "performance_sensitive": {"type": "boolean"}
            }
          },
          "risk_flags": {
            "type": "object",
            "additionalProperties": false,
            "required": ["concurrency", "migration", "security", "public_contract", "cross_subsystem"],
            "properties": {
              "concurrency": {"type": "boolean"},
              "migration": {"type": "boolean"},
              "security": {"type": "boolean"},
              "public_contract": {"type": "boolean"},
              "cross_subsystem": {"type": "boolean"}
            }
          }
        }
      }
    },
    "native_eligibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eligible", "rationale"],
      "properties": {"eligible": {"type": "boolean"}, "rationale": {"type": "string", "minLength": 1}}
    },
    "contextual_risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "area", "covered_by"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "area": {"type": "string", "minLength": 1},
          "covered_by": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
        }
      }
    },
    "user_directive_coverage": {
      "type": "array",
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["directive", "required_lenses", "covered_by", "rationale"],
        "properties": {
          "directive": {"type": "string", "minLength": 1},
          "required_lenses": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "covered_by": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "rationale": {"type": "string", "minLength": 1}
        }
      }
    },
    "slices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "area", "primary_scope", "context_scope", "lenses", "risks", "focus", "rationale", "rule_sources"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"},
          "kind": {"enum": ["native", "focused"]},
          "area": {"type": "string", "minLength": 1},
          "primary_scope": {"$ref": "#/$defs/scope"},
          "context_scope": {"$ref": "#/$defs/scope"},
          "lenses": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "risks": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "focus": {"type": "string", "minLength": 1},
          "rationale": {"type": "string", "minLength": 1},
          "rule_sources": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    }
  },
  "$defs": {
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "symbols"],
      "properties": {
        "files": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "symbols": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    }
  }
}
